# NYC DEP Water Usage Emailer - Environment Configuration
# Copy this file to .env and fill in your actual values

# DEP Portal Credentials
# Your DEP portal login email address
DEP_USERNAME=your_dep_email@example.com

# Your DEP portal password
DEP_PASSWORD=your_dep_password

# Account-specific IDs from your DEP account
# These can be found in your DEP portal account details
DEP_ACCOUNT_ID=0000553243
DEP_SERVICE_ID=S0003xy317960
DEP_METER_ID=M0001xy97578
DEP_REGISTER_ID=R000013968

# Gmail Settings for Email Reports
# Your Gmail address for sending emails
GMAIL_ADDRESS=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Generate this at: https://myaccount.google.com/apppasswords
# Enable 2-Step Verification first, then create an App Password for "Mail"
GMAIL_APP_PASSWORD=your_16_character_app_password

# Email address where you want to receive the water usage reports
# Can be the same as GMAIL_ADDRESS or a different email
EMAIL_TO=recipient@example.com

# Optional: Browser Mode
# Set to 'true' to run browser in headless mode (invisible)
# Set to 'false' to see the browser automation (useful for debugging)
HEADLESS=false